generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Filme {
  id              Int      @id @default(autoincrement())
  nome            String   @db.VarChar(200)
  sinopse         String?  @db.Text
  genero          String?  @db.VarChar(100)
  ano_lancamento  Int?
  diretor         String?  @db.VarChar(150)
  duracao_minutos Int?
  classificacao   String?  @db.VarChar(10)
  nota            Decimal? @db.Decimal(3, 1)

  @@map("filme")
}